#!/usr/bin/make -f
# wazo-plugind install rules for optimo/wazo-dird-optimogo (plugin_format_version 2).
#
# Invoked by the generated debian maintainer scripts (confirmed against
# wazo-plugind 26.04 templates) as:
#   rules install     -> postinst   (configure): install package + enable backend + reload dird
#   rules uninstall    -> prerm      (remove):    remove package + drop config + reload dird
#   rules postrm       -> postrm     (purge/remove): final cleanup
#
# wazo-plugind installs the whole plugin tree under
#   /usr/lib/wazo-plugind/plugins/optimo/wazo-dird-optimogo/
# so PLUGIN_DIR is the parent of this wazo/ directory (where setup.py lives).
PLUGIN_DIR := $(abspath $(dir $(lastword $(MAKEFILE_LIST)))/..)

# The package serves two services (they share the system Python):
#   - wazo-dird: the source backend. dird only loads/lists backends present in
#     enabled_plugins.backends, so we drop a conf.d to enable optimogo.
#   - wazo-ui:   the admin form plugin. wazo-ui only loads plugins enabled in its
#     own enabled_plugins, so we drop a conf.d to enable optimogo_source.
# Without each drop-in the corresponding side is installed but inert.
CONF := 50-wazo-dird-optimogo.yml
DIRD_CONFD := /etc/wazo-dird/conf.d
UI_CONFD := /etc/wazo-ui/conf.d

.PHONY: install uninstall postrm

install:
	pip3 install --break-system-packages --no-deps --upgrade "$(PLUGIN_DIR)"
	install -m 644 "$(PLUGIN_DIR)/etc/wazo-dird/conf.d/$(CONF)" "$(DIRD_CONFD)/$(CONF)"
	install -m 644 "$(PLUGIN_DIR)/etc/wazo-ui/conf.d/$(CONF)" "$(UI_CONFD)/$(CONF)"
	systemctl restart wazo-dird
	systemctl restart wazo-ui

uninstall:
	pip3 uninstall --yes wazo-dird-optimogo || true
	rm -f "$(DIRD_CONFD)/$(CONF)" "$(UI_CONFD)/$(CONF)"
	systemctl restart wazo-dird
	systemctl restart wazo-ui

postrm:
	rm -f "$(DIRD_CONFD)/$(CONF)" "$(UI_CONFD)/$(CONF)"
